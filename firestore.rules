rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'ibgroup.live@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
             data.createdAt == request.time &&
             (data.get('email', '') == '' || (data.email is string && data.email.size() <= 100)) &&
             (data.get('whatsapp', '') == '' || (data.whatsapp is string && data.whatsapp.size() <= 100)) &&
             (data.get('subject', '') == '' || (data.subject is string && data.subject.size() <= 200));
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow list, get, delete: if isAdmin();
      allow update: if false; // Inquiries are immutable
    }
  }
}
