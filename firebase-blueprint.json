{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "Visitor contact or service request information.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the visitor" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "subject": { "type": "string", "description": "Subject of inquiry" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time of inquiry" }
      },
      "required": ["name", "message", "createdAt"]
    }
  },
  "firestore": {
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of visitor inquiries and feedback."
    }
  }
}
